{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FilmsData",
  "type": "object",
  "required": ["films"],
  "additionalProperties": false,
  "properties": {
    "films": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "year",
          "genres",
          "director",
          "actors",
          "rating",
          "durationMin",
          "ageLimit",
          "status",
          "description",
          "language"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^f[0-9]{3,}$"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "year": {
            "type": "integer",
            "minimum": 1900,
            "maximum": 2100
          },
          "genres": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["action", "comedy", "drama", "sci-fi", "animation", "thriller"]
            }
          },
          "director": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          },
          "actors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2,
              "maxLength": 80
            }
          },
          "rating": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },
          "durationMin": {
            "type": "integer",
            "minimum": 40,
            "maximum": 300
          },
          "ageLimit": {
            "type": "integer",
            "enum": [0, 7, 10, 12, 16, 18]
          },
          "status": {
            "type": "string",
            "enum": ["available", "coming_soon", "archived"]
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          },
          "language": {
            "type": "string",
            "enum": ["FR", "EN", "ES", "JP", "KO", "AR", "OTHER"]
          }
        }
      }
    }
  }
}
