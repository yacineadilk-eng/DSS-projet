{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UsersData",
  "type": "object",
  "required": ["users"],
  "additionalProperties": false,
  "properties": {
    "users": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "firstName",
          "lastName",
          "age",
          "email",
          "passwordHash",
          "role",
          "isEmailVerified",
          "verificationToken",
          "favoriteGenres",
          "watchedFilmIds"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^u[0-9]{3,}$"
          },
          "firstName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "lastName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "age": {
            "type": "integer",
            "minimum": 10,
            "maximum": 100
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "passwordHash": {
            "type": "string",
            "minLength": 20,
            "maxLength": 255
          },
          "role": {
            "type": "string",
            "enum": ["admin", "user"]
          },
          "isEmailVerified": {
            "type": "boolean"
          },
          "verificationToken": {
            "type": "string",
            "maxLength": 120
          },
          "favoriteGenres": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["action", "comedy", "drama", "sci-fi", "animation", "thriller"]
            }
          },
          "watchedFilmIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^f[0-9]{3,}$"
            }
          }
        }
      }
    }
  }
}
