{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CategoriesData",
  "type": "object",
  "required": ["categories"],
  "additionalProperties": false,
  "properties": {
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["action", "comedy", "drama", "sci-fi", "animation", "thriller"]
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          },
          "description": {
            "type": "string",
            "minLength": 5,
            "maxLength": 200
          }
        }
      }
    }
  }
}
